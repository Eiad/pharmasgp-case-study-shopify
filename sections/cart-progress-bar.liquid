{%- comment -%}
  Cart Progress Bar
  Shows customers how close they are to getting:
    1. Free shipping (default: $39.99)
    2. A free gift product (default: $99.99)
  Settings can be changed in the Theme Editor — no code needed
{%- endcomment -%}

{%- liquid
  # Convert text settings to cents (Shopify stores prices in cents)
  assign shipping_limit = section.settings.free_shipping_threshold | plus: 0 | times: 100 | round
  assign gift_limit = section.settings.free_gift_threshold | plus: 0 | times: 100 | round
  assign gift_variant_id = section.settings.free_gift_variant_id
  assign cart_total = cart.items_subtotal_price

  # Figure out how full the bar should be
  # Left half (0-50%) = shipping goal, right half (50-100%) = gift goal
  # This way the bar always grows and never goes backwards
  if cart_total >= gift_limit
    assign progress = 100
    assign status_text = 'You got free shipping & a free gift!'
    assign helper_text = ''
    assign bar_state = 'complete'
  elsif cart_total >= shipping_limit
    assign gift_range = gift_limit | minus: shipping_limit
    assign gift_progress = cart_total | minus: shipping_limit | times: 50 | divided_by: gift_range
    assign progress = 50 | plus: gift_progress
    assign remaining_cents = gift_limit | minus: cart_total
    assign remaining_formatted = remaining_cents | money
    assign gift_limit_formatted = gift_limit | money
    assign status_text = 'Free gift at ' | append: gift_limit_formatted
    assign helper_text = 'Just ' | append: remaining_formatted | append: ' away from a free gift!'
    assign bar_state = 'active'
  else
    assign progress = cart_total | times: 50 | divided_by: shipping_limit
    assign remaining_cents = shipping_limit | minus: cart_total
    assign remaining_formatted = remaining_cents | money
    assign shipping_limit_formatted = shipping_limit | money
    assign status_text = 'Free shipping at ' | append: shipping_limit_formatted
    assign helper_text = 'Just ' | append: remaining_formatted | append: ' away from free shipping!'
    assign bar_state = 'active'
  endif
-%}

{% if cart.item_count > 0 %}
<!-- Progress bar wrapper -->
<!-- data-* attributes let JavaScript read the settings -->
<!-- role="progressbar" + aria-* for screen readers -->
<div class="cart-progress-section">
  <div class="cart-progress"
       id="cart-progress-bar"
       data-section-id="{{ section.id }}"
       data-shipping-threshold="{{ shipping_limit }}"
       data-gift-threshold="{{ gift_limit }}"
       data-gift-variant-id="{{ gift_variant_id }}"
       role="progressbar"
       aria-valuenow="{{ progress }}"
       aria-valuemin="0"
       aria-valuemax="100"
       aria-label="{{ status_text }}">

    <!-- Text above the bar: current goal -->
    <p class="cart-progress__status{% if bar_state == 'complete' %} cart-progress__status--success{% endif %}">
      {{ status_text }}
    </p>

    <!-- The bar: gray track with colored fill -->
    <div class="cart-progress__track">
      <div class="cart-progress__fill{% if bar_state == 'complete' %} cart-progress__fill--complete{% endif %}"
           style="width: {{ progress | at_most: 100 }}%">
      </div>
    </div>

    <!-- Text below the bar: how much more to spend -->
    {% if helper_text != blank %}
      <p class="cart-progress__helper">{{ helper_text }}</p>
    {% endif %}
  </div>
</div>
{% endif %}

<style>
  .cart-progress-section {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* The rounded card that wraps everything */
  .cart-progress {
    background: #F0F4F6;
    border-radius: 10px;
    padding: 14px 16px;
    margin: 16px 0;
    transition: background 0.4s ease;
  }
  /* Turns green when both rewards are unlocked */
  .cart-progress.is-complete { background: #e8f5e0; }

  /* Text above the bar */
  .cart-progress__status {
    font-size: 14px;
    font-weight: 500;
    color: #002F6C;
    margin: 0 0 10px;
    transition: color 0.4s ease;
  }
  /* Green text when done */
  .cart-progress__status--success { color: #4A9500; }

  /* The gray background of the bar */
  .cart-progress__track {
    height: 7px;
    background: #d0d8de;
    border-radius: 4px;
    overflow: hidden;
  }

  /* The blue fill that grows as you add items */
  .cart-progress__fill {
    height: 100%;
    background: #002F6C;
    border-radius: 4px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  /* Green fill when done */
  .cart-progress__fill--complete { background: #4A9500; }

  /* Small text below the bar */
  .cart-progress__helper {
    font-size: 12px;
    color: #48494B;
    margin: 8px 0 0;
  }
</style>

<!-- JavaScript: updates the bar in real-time + auto-adds/removes free gift -->
<script>
  (function() {
    var el = document.getElementById('cart-progress-bar');
    if (!el) return;

    // Read settings from HTML data attributes
    var SHIPPING = parseInt(el.dataset.shippingThreshold, 10);
    var GIFT = parseInt(el.dataset.giftThreshold, 10);
    var GIFT_VARIANT = el.dataset.giftVariantId;
    var debounceTimer;
    var isUpdating = false;

    // Turn cents into a formatted dollar string using the store's format
    function formatMoney(cents) {
      return '$' + (cents / 100).toFixed(2);
    }

    // Get the current cart from Shopify
    async function getCart() {
      var res = await fetch('/cart.json');
      if (!res.ok) throw new Error('Failed to fetch cart');
      return res.json();
    }

    // Add the free gift product to the cart
    async function addGift() {
      var res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: parseInt(GIFT_VARIANT, 10), quantity: 1 }] })
      });
      // Handle rate limiting (429)
      if (res.status === 429) {
        await new Promise(function(r) { setTimeout(r, 1000); });
        return addGift();
      }
    }

    // Remove the free gift from the cart
    async function removeGift(lineIndex) {
      var res = await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: lineIndex, quantity: 0 })
      });
      if (res.status === 429) {
        await new Promise(function(r) { setTimeout(r, 1000); });
        return removeGift(lineIndex);
      }
    }

    // Update the progress bar UI
    function updateUI(total) {
      var progress, statusText, helperText, isComplete;

      if (total >= GIFT) {
        progress = 100;
        statusText = 'You got free shipping & a free gift!';
        helperText = '';
        isComplete = true;
      } else if (total >= SHIPPING) {
        progress = 50 + ((total - SHIPPING) / (GIFT - SHIPPING)) * 50;
        statusText = 'Free gift at ' + formatMoney(GIFT);
        helperText = 'Just ' + formatMoney(GIFT - total) + ' away from a free gift!';
        isComplete = false;
      } else {
        progress = (total / SHIPPING) * 50;
        statusText = 'Free shipping at ' + formatMoney(SHIPPING);
        helperText = 'Just ' + formatMoney(SHIPPING - total) + ' away from free shipping!';
        isComplete = false;
      }

      // Update the DOM
      var fill = el.querySelector('.cart-progress__fill');
      var status = el.querySelector('.cart-progress__status');
      var helper = el.querySelector('.cart-progress__helper');

      if (fill) {
        fill.style.width = Math.min(progress, 100) + '%';
        fill.classList.toggle('cart-progress__fill--complete', isComplete);
      }
      if (status) {
        status.textContent = statusText;
        status.classList.toggle('cart-progress__status--success', isComplete);
      }
      if (helper) {
        helper.textContent = helperText;
        helper.style.display = helperText ? '' : 'none';
      }

      el.classList.toggle('is-complete', isComplete);
      el.setAttribute('aria-valuenow', Math.round(progress));
      el.setAttribute('aria-label', statusText);
    }

    // Main update: check cart, manage gift, update bar
    async function update() {
      if (isUpdating) return;
      isUpdating = true;

      try {
        var cart = await getCart();
        var total = cart.items_subtotal_price;

        // Check if gift is already in the cart
        var hasGift = cart.items.some(function(item) {
          return String(item.variant_id) === String(GIFT_VARIANT);
        });

        // Auto-add gift when above limit, remove when below
        if (GIFT_VARIANT && total >= GIFT && !hasGift) {
          await addGift();
          isUpdating = false;
          return update();
        }
        if (GIFT_VARIANT && total < GIFT && hasGift) {
          var idx = cart.items.findIndex(function(item) {
            return String(item.variant_id) === String(GIFT_VARIANT);
          });
          if (idx !== -1) {
            await removeGift(idx + 1); // Shopify lines are 1-indexed
            isUpdating = false;
            return update();
          }
        }

        updateUI(total);
      } catch (e) {
        console.error('Cart progress bar update failed:', e);
      } finally {
        isUpdating = false;
      }
    }

    // Debounced update
    function scheduleUpdate() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(update, 300);
    }

    // Detect cart changes by intercepting fetch calls to /cart/ endpoints
    var originalFetch = window.fetch;
    window.fetch = function() {
      var args = arguments;
      var url = typeof args[0] === 'string' ? args[0] : (args[0] && args[0].url ? args[0].url : '');

      return originalFetch.apply(this, args).then(function(response) {
        if (url.indexOf('/cart/') !== -1 && url.indexOf('/cart.json') === -1) {
          scheduleUpdate();
        }
        return response;
      });
    };

    // Also listen for the theme's cart update event (Horizon theme uses 'cart:update')
    document.addEventListener('cart:update', scheduleUpdate);

    // Run on page load to handle gift management
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', update);
    } else {
      update();
    }
  })();
</script>

{% schema %}
{
  "name": "Cart Progress Bar",
  "settings": [
    {
      "type": "text",
      "id": "free_shipping_threshold",
      "label": "Free Shipping Limit ($)",
      "default": "39.99",
      "info": "How much the customer needs to spend for free shipping"
    },
    {
      "type": "text",
      "id": "free_gift_threshold",
      "label": "Free Gift Limit ($)",
      "default": "99.99",
      "info": "How much the customer needs to spend to get a free gift"
    },
    {
      "type": "text",
      "id": "free_gift_variant_id",
      "label": "Gift Product Variant ID",
      "default": "43379474432059",
      "info": "The ID of the free gift product (find it in Shopify Admin > Products)"
    }
  ],
  "presets": [
    {
      "name": "Cart Progress Bar"
    }
  ]
}
{% endschema %}
