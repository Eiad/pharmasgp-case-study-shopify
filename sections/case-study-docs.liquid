<div class="cs-page">

  <!-- HERO -->
  <div class="cs-hero">
    <p class="cs-label">Case Study -PharmaSGP eCommerce</p>
    <h1 class="cs-title">Cart Progress Bar</h1>
    <p class="cs-subtitle">A Tiered Incentive System for Shopify</p>
    <div class="cs-line"></div>
    <p class="cs-meta">Shopify Liquid · HTML · CSS · JavaScript<br>Ashraf · April 2026</p>
  </div>

  <!-- THE CHALLENGE -->
  <div class="cs-section cs-section--light">
    <p class="cs-label">The Challenge</p>
    <h2>Motivating Customers to Add More</h2>
    <p class="cs-body">
      Design and build a dynamic progress bar for the shopping cart that guides
      customers through two reward tiers: <strong>free shipping</strong> at $39.99 and a
      <strong>free gift product</strong> at $99.99. The bar updates in real-time as the
      cart value changes, and automatically adds the gift when the threshold is reached.
    </p>
    <div class="cs-insight">
      <strong>Why it works:</strong> The goal-gradient effect -people accelerate effort
      as they approach a reward. A visible progress bar leverages this to increase average order value.
    </div>
  </div>

  <!-- TRY IT LIVE -->
  <div class="cs-section">
    <p class="cs-label">Interactive Demo</p>
    <h2>Try It Live</h2>
    <p class="cs-body">
      Add <strong>Kijimea K53 Advance</strong> to your cart and change the quantity to see
      the progress bar respond in real-time. Watch the bar grow, the text update, and the
      free gift appear automatically.
    </p>
    <div class="cs-states">
      <div class="cs-state">
        <span class="cs-state__label">1 item ($29.99)</span>
        <span class="cs-state__desc">Working toward free shipping</span>
      </div>
      <div class="cs-state">
        <span class="cs-state__label">2 items ($59.98)</span>
        <span class="cs-state__desc">Shipping unlocked, working toward gift</span>
      </div>
      <div class="cs-state cs-state--success">
        <span class="cs-state__label">4 items ($119.96)</span>
        <span class="cs-state__desc">Both rewards unlocked + gift auto-added</span>
      </div>
    </div>
    {%- assign cs_product = all_products['kijimea-k53-advance'] -%}
    {%- if cs_product != blank -%}
      {%- assign cs_variant = cs_product.selected_or_first_available_variant -%}
      <div class="cs-product-card">
        <div class="cs-product-card__image">
          {{ cs_product.featured_image | image_url: width: 160 | image_tag: class: 'cs-product-card__img' }}
        </div>
        <div class="cs-product-card__info">
          <h3 class="cs-product-card__title">{{ cs_product.title }}</h3>
          <div class="cs-product-card__price">
            <span class="cs-product-card__current">{{ cs_variant.price | money }}</span>
            {%- if cs_variant.compare_at_price > cs_variant.price -%}
              <s class="cs-product-card__compare">{{ cs_variant.compare_at_price | money }}</s>
            {%- endif -%}
          </div>
          <button type="button"
                  class="cs-cta cs-product-card__btn"
                  id="cs-atc-btn"
                  data-variant-id="{{ cs_variant.id }}"
                  data-cart-url="{{ routes.cart_add_url | append: '.js' }}">
            Add to Cart
          </button>
        </div>
      </div>
    {%- else -%}
      <a href="/collections/all" class="cs-cta">Browse Products →</a>
    {%- endif -%}

    <script>
      (function() {
        var btn = document.getElementById('cs-atc-btn');
        if (!btn) return;

        btn.addEventListener('click', function() {
          if (btn.disabled) return;
          btn.disabled = true;
          var originalText = btn.textContent;
          btn.textContent = 'Adding...';

          var variantId = parseInt(btn.dataset.variantId, 10);
          var cartUrl = btn.dataset.cartUrl;

          // Get cart drawer section ID for fresh HTML in response
          var comp = document.querySelector('cart-items-component');
          var sectionId = comp ? comp.dataset.sectionId : '';
          var body = { items: [{ id: variantId, quantity: 1 }] };
          if (sectionId) body.sections = sectionId;

          fetch(cartUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
          })
          .then(function(res) {
            if (!res.ok) throw new Error('Add to cart failed');
            return res.json();
          })
          .then(function(data) {
            // Update drawer content with fresh HTML from response
            if (data.sections && comp && sectionId) {
              var html = data.sections[sectionId];
              if (html) {
                var parser = new DOMParser();
                var doc = parser.parseFromString(html, 'text/html');
                var newComp = doc.querySelector('cart-items-component');
                if (newComp) {
                  Array.from(comp.children).forEach(function(c) { c.remove(); });
                  Array.from(newComp.children).forEach(function(c) { comp.appendChild(c); });
                }
              }
            }

            // Open cart drawer
            var drawer = document.querySelector('cart-drawer-component');
            if (drawer && drawer.open) {
              drawer.open();
            }

            // Success state
            btn.textContent = '✓ Added!';
            btn.style.background = '#4A9500';
            setTimeout(function() {
              btn.textContent = originalText;
              btn.style.background = '';
              btn.disabled = false;
            }, 2000);
          })
          .catch(function() {
            btn.textContent = 'Failed -try again';
            btn.style.background = '#c0392b';
            setTimeout(function() {
              btn.textContent = originalText;
              btn.style.background = '';
              btn.disabled = false;
            }, 2000);
          });
        });
      })();
    </script>
  </div>

  <!-- HOW IT WORKS -->
  <div class="cs-section cs-section--light">
    <p class="cs-label">Technical Approach</p>
    <h2>How It Works</h2>
    <div class="cs-grid">
      <div class="cs-card">
        <h3>Server-Side First</h3>
        <p>Liquid calculates the progress bar state on the server. The correct state is visible immediately -no flash of wrong content, no layout shift. Works even if JavaScript fails.</p>
      </div>
      <div class="cs-card">
        <h3>Real-Time Updates</h3>
        <p>JavaScript intercepts cart API calls and updates the bar dynamically. A loading overlay shows during gift operations. The theme's own morph system handles section re-rendering.</p>
      </div>
      <div class="cs-card">
        <h3>One File, Two Contexts</h3>
        <p>All code lives in a single snippet (<code>cart-progress-bar.liquid</code>). It renders in both the cart drawer and the full cart page -same component, same behavior.</p>
      </div>
      <div class="cs-card">
        <h3>Smart Gift Management</h3>
        <p>The gift product auto-adds when the threshold is reached and auto-removes when it drops below. Quantity is locked to 1, marked with a "Free Gift" badge, and controls are hidden.</p>
      </div>
    </div>
  </div>

  <!-- GIFT PRICING -->
  <div class="cs-section">
    <p class="cs-label">Gift Product Strategy</p>
    <h2>Real Pricing with Automatic Discount</h2>
    <p class="cs-body">
      The gift product (Kijimea Liquid) has a <strong>real price of $13.99</strong> - it's not a fake $0 product.
      A Shopify <strong>Buy X Get Y automatic discount</strong> makes it free when the cart threshold is reached.
    </p>
    <div class="cs-grid">
      <div class="cs-card">
        <h3>How It Works</h3>
        <p>When the customer spends $99.99+ on Kijimea K53 Advance, Shopify's native discount engine automatically applies 100% off on the Kijimea Liquid. The cart shows <s>$13.99</s> $0.00 with a discount line.</p>
      </div>
      <div class="cs-card">
        <h3>Why Real Pricing</h3>
        <p>A $0 product feels fake. A $13.99 product discounted to free feels like a genuine reward. The customer sees the value they're getting, which reinforces the incentive to keep shopping.</p>
      </div>
      <div class="cs-card">
        <h3>Circular Dependency Prevention</h3>
        <p>The gift's price could inflate the cart subtotal above the threshold, keeping itself in the cart. The progress bar excludes the gift from its subtotal calculation entirely - only real purchases count.</p>
      </div>
      <div class="cs-card">
        <h3>Native Shopify Discount</h3>
        <p>Uses Shopify's built-in Buy X Get Y discount type - no apps, no workarounds. The discount applies in the cart AND at checkout. Limited to 1 free gift per order.</p>
      </div>
    </div>
  </div>

  <!-- CI/CD -->
  <div class="cs-section">
    <p class="cs-label">Development Workflow</p>
    <h2>CI/CD Pipeline</h2>
    <p class="cs-body">
      Every push to <code>main</code> automatically lints the Liquid code and deploys to the store.
      No manual theme uploads needed.
    </p>
    <div class="cs-pipeline">
      <div class="cs-pipe-step">
        <span class="cs-pipe-icon">1</span>
        <span class="cs-pipe-text">Push to GitHub</span>
      </div>
      <div class="cs-pipe-arrow">→</div>
      <div class="cs-pipe-step">
        <span class="cs-pipe-icon">2</span>
        <span class="cs-pipe-text">Theme Check (Lint)</span>
      </div>
      <div class="cs-pipe-arrow">→</div>
      <div class="cs-pipe-step">
        <span class="cs-pipe-icon">3</span>
        <span class="cs-pipe-text">Auto-Deploy to Store</span>
      </div>
    </div>
    <div class="cs-details">
      <p><strong>Pull Requests:</strong> Theme Check runs automatically with inline annotations</p>
      <p><strong>Settings Protected:</strong> <code>.shopifyignore</code> prevents CI from overwriting admin-configured settings</p>
      <p><strong>Concurrency:</strong> Rapid pushes cancel old deploys -only the latest runs</p>
    </div>
  </div>

  <!-- DEV ENVIRONMENT -->
  <div class="cs-section cs-section--light">
    <p class="cs-label">Development Environment</p>
    <h2>Shopify CLI Integration</h2>
    <p class="cs-body">
      The entire development workflow runs through the <strong>Shopify CLI</strong>, connected
      directly to the dev store. No manual file uploads, no copy-pasting in the admin.
    </p>
    <div class="cs-grid">
      <div class="cs-card">
        <h3>Theme Sync</h3>
        <p><code>shopify theme pull</code> downloads the live theme locally. <code>shopify theme push</code> deploys changes. The CLI handles auth, file diffing, and conflict detection.</p>
      </div>
      <div class="cs-card">
        <h3>Product Management</h3>
        <p>Products and variants created via the <strong>Admin GraphQL API</strong> through <code>shopify store execute</code>. Prices, images, and publication status -all from the terminal.</p>
      </div>
      <div class="cs-card">
        <h3>Pages from Code</h3>
        <p>This documentation page is a custom template (<code>page.case-study.json</code>) with a dedicated section. The template lives in the repo -deployed automatically via CI/CD.</p>
      </div>
      <div class="cs-card">
        <h3>Settings via Schema</h3>
        <p>Progress bar thresholds and gift product are configured in <code>settings_schema.json</code>. Store managers change values in the Theme Editor -no developer needed.</p>
      </div>
    </div>
    <div class="cs-details" style="margin-top: 24px;">
      <p><strong>Local Dev:</strong> <code>shopify theme dev</code> serves the theme locally with hot reload</p>
      <p><strong>Store Auth:</strong> <code>shopify store auth</code> enables GraphQL queries against the store</p>
      <p><strong>Version Control:</strong> Full theme in Git -every change is tracked, reviewable, and reversible</p>
    </div>
  </div>

  <!-- KEY DECISIONS -->
  <div class="cs-section">
    <p class="cs-label">Architecture Decisions</p>
    <h2>Why I Built It This Way</h2>
    <div class="cs-decisions">
      <div class="cs-decision">
        <h3>Snippet over Section</h3>
        <p>Sections only render on specific pages. A snippet can be included in both the cart drawer (header) and the cart page -one component, universal coverage.</p>
      </div>
      <div class="cs-decision">
        <h3>Fetch Intercept over Theme Events</h3>
        <p>Horizon's <code>cart:update</code> event is theme-specific. Intercepting <code>fetch</code> calls to <code>/cart/</code> endpoints works with any Shopify theme -portable and reliable.</p>
      </div>
      <div class="cs-decision">
        <h3>Continuous Progress Bar</h3>
        <p>The bar maps 0-50% to shipping and 50-100% to the gift. This prevents the bar from shrinking when crossing the first threshold -it only ever grows.</p>
      </div>
      <div class="cs-decision">
        <h3>Hidden Line Item Properties</h3>
        <p>The gift is added with <code>_gift: "true"</code> property. The underscore prefix hides it from customers. Liquid uses it to show the "Free Gift" badge and hide quantity controls.</p>
      </div>
    </div>
  </div>

  <!-- LINKS -->
  <div class="cs-section cs-footer">
    <h2>Resources</h2>
    <div class="cs-links">
      <a href="https://github.com/Eiad/pharmasgp-case-study-shopify" target="_blank" class="cs-link">
        Source Code (GitHub) →
      </a>
      <a href="https://pharmasgp-case-study.vercel.app" target="_blank" class="cs-link">
        Interactive Presentation →
      </a>
      <a href="/products/kijimea-k53-advance" class="cs-link">
        Try the Demo →
      </a>
    </div>
    <p class="cs-footer-text">Ashraf · Case Study Submission · PharmaSGP · April 2026</p>
  </div>

</div>

{% stylesheet %}
  .cs-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: #48494B;
    line-height: 1.7;
  }

  /* Hero */
  .cs-hero {
    padding: 60px 0 40px;
  }
  .cs-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #002F6C;
    margin: 0 0 8px;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .cs-subtitle {
    font-size: 1.1rem;
    color: #6b6d70;
    font-weight: 300;
    margin: 0;
  }
  .cs-line {
    width: 50px;
    height: 3px;
    background: #002F6C;
    border-radius: 2px;
    margin: 24px 0;
  }
  .cs-meta {
    font-size: 0.85rem;
    color: #6b6d70;
    line-height: 1.8;
  }

  /* Labels */
  .cs-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #002F6C;
    opacity: 0.6;
    margin: 0 0 12px;
  }

  /* Sections */
  .cs-section {
    padding: 48px 0;
    border-top: 1px solid #F0F4F6;
  }
  .cs-section--light {
    background: #F0F4F6;
    margin: 0 -20px;
    padding: 48px 20px;
    border-radius: 0;
  }
  .cs-section h2 {
    font-size: 1.6rem;
    font-weight: 600;
    color: #002F6C;
    margin: 0 0 16px;
    letter-spacing: -0.01em;
  }
  .cs-body {
    font-size: 1rem;
    max-width: 600px;
    margin: 0 0 24px;
  }

  /* Insight box */
  .cs-insight {
    background: white;
    border-left: 3px solid #002F6C;
    padding: 16px 20px;
    border-radius: 0 8px 8px 0;
    font-size: 0.9rem;
    color: #6b6d70;
    margin-top: 20px;
  }
  .cs-insight strong { color: #002F6C; }

  /* State cards */
  .cs-states {
    display: flex;
    gap: 12px;
    margin: 24px 0;
    flex-wrap: wrap;
  }
  .cs-state {
    flex: 1;
    min-width: 180px;
    background: #F0F4F6;
    border-radius: 8px;
    padding: 14px 16px;
  }
  .cs-state--success {
    background: #e8f5e0;
  }
  .cs-state__label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #002F6C;
    margin-bottom: 4px;
  }
  .cs-state--success .cs-state__label { color: #4A9500; }
  .cs-state__desc {
    font-size: 0.78rem;
    color: #6b6d70;
  }

  /* CTA */
  .cs-cta {
    display: inline-block;
    background: #002F6C;
    color: white;
    padding: 12px 28px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }
  .cs-cta:hover { background: #003d8f; color: white; }
  .cs-cta:disabled { opacity: 0.7; cursor: wait; }

  /* Product card */
  .cs-product-card {
    display: flex;
    align-items: center;
    gap: 20px;
    background: #F0F4F6;
    border-radius: 12px;
    padding: 20px;
    margin: 24px 0 0;
    border: 1px solid rgba(0,47,108,0.06);
  }
  .cs-product-card__image {
    flex-shrink: 0;
    width: 100px;
    height: 100px;
    border-radius: 8px;
    overflow: hidden;
    background: white;
  }
  .cs-product-card__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .cs-product-card__info {
    flex: 1;
  }
  .cs-product-card__title {
    font-size: 1rem;
    font-weight: 600;
    color: #002F6C;
    margin: 0 0 6px;
  }
  .cs-product-card__price {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .cs-product-card__current {
    font-size: 1.1rem;
    font-weight: 700;
    color: #002F6C;
  }
  .cs-product-card__compare {
    font-size: 0.85rem;
    color: #6b6d70;
    text-decoration: line-through;
  }
  .cs-product-card__btn {
    margin: 0;
    padding: 10px 24px;
  }
  @media (max-width: 480px) {
    .cs-product-card {
      flex-direction: column;
      text-align: center;
    }
    .cs-product-card__price { justify-content: center; }
  }

  /* Grid cards */
  .cs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 24px;
  }
  @media (max-width: 600px) {
    .cs-grid { grid-template-columns: 1fr; }
  }
  .cs-card {
    background: white;
    border-radius: 10px;
    padding: 20px;
    border: 1px solid rgba(0,47,108,0.06);
  }
  .cs-card h3 {
    font-size: 0.95rem;
    color: #002F6C;
    margin: 0 0 8px;
  }
  .cs-card p {
    font-size: 0.85rem;
    color: #6b6d70;
    margin: 0;
    line-height: 1.6;
  }
  .cs-card code {
    background: #F0F4F6;
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 0.8rem;
  }

  /* Pipeline */
  .cs-pipeline {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 24px 0;
    flex-wrap: wrap;
  }
  .cs-pipe-step {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #F0F4F6;
    padding: 12px 18px;
    border-radius: 8px;
  }
  .cs-pipe-icon {
    width: 28px;
    height: 28px;
    background: #002F6C;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .cs-pipe-text {
    font-size: 0.85rem;
    font-weight: 500;
    color: #48494B;
  }
  .cs-pipe-arrow {
    color: #002F6C;
    font-size: 1.2rem;
    font-weight: 700;
  }
  .cs-details {
    margin-top: 20px;
  }
  .cs-details p {
    font-size: 0.85rem;
    color: #6b6d70;
    margin: 6px 0;
  }
  .cs-details strong { color: #48494B; }
  .cs-details code {
    background: #F0F4F6;
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 0.8rem;
  }

  /* Decisions */
  .cs-decisions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 24px;
  }
  @media (max-width: 600px) {
    .cs-decisions { grid-template-columns: 1fr; }
  }
  .cs-decision {
    background: white;
    padding: 20px;
    border-radius: 10px;
    border-left: 3px solid #002F6C;
  }
  .cs-decision h3 {
    font-size: 0.9rem;
    color: #002F6C;
    margin: 0 0 8px;
  }
  .cs-decision p {
    font-size: 0.82rem;
    color: #6b6d70;
    margin: 0;
    line-height: 1.6;
  }
  .cs-decision code {
    background: #F0F4F6;
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 0.78rem;
  }

  /* Footer / Links */
  .cs-footer {
    text-align: center;
    padding: 48px 0 60px;
  }
  .cs-footer h2 {
    color: #002F6C;
  }
  .cs-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin: 20px 0;
  }
  .cs-link {
    display: inline-block;
    padding: 10px 20px;
    border: 1.5px solid rgba(0,47,108,0.15);
    border-radius: 8px;
    text-decoration: none;
    color: #002F6C;
    font-weight: 500;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .cs-link:hover {
    background: #002F6C;
    color: white;
    border-color: #002F6C;
  }
  .cs-footer-text {
    font-size: 0.8rem;
    color: #6b6d70;
    margin-top: 24px;
  }

  /* Mobile */
  @media (max-width: 600px) {
    .cs-title { font-size: 1.8rem; }
    .cs-section h2 { font-size: 1.3rem; }
    .cs-hero { padding: 40px 0 24px; }
    .cs-pipeline { flex-direction: column; align-items: flex-start; }
    .cs-pipe-arrow { transform: rotate(90deg); }
    .cs-states { flex-direction: column; }
  }
{% endstylesheet %}

