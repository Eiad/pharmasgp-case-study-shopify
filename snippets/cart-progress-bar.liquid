{%- comment -%}
  Cart Progress Bar — Free shipping + free gift incentive
  Rendered in both the cart drawer and cart page.
  Settings configured in Theme Editor > Settings > Cart Progress Bar.
{%- endcomment -%}

{%- liquid
  assign shipping_limit = settings.cart_progress_shipping_threshold | plus: 0 | times: 100 | round
  assign gift_limit = settings.cart_progress_gift_threshold | plus: 0 | times: 100 | round
  assign gift_variant_id = settings.cart_progress_gift_variant_id
  assign cart_total = cart.items_subtotal_price

  if cart_total >= gift_limit
    assign progress = 100
    assign status_text = 'You got free shipping & a free gift!'
    assign helper_text = ''
    assign bar_state = 'complete'
  elsif cart_total >= shipping_limit
    assign gift_range = gift_limit | minus: shipping_limit
    assign gift_progress = cart_total | minus: shipping_limit | times: 50 | divided_by: gift_range
    assign progress = 50 | plus: gift_progress
    assign remaining_cents = gift_limit | minus: cart_total
    assign remaining_formatted = remaining_cents | money
    assign gift_limit_formatted = gift_limit | money
    assign status_text = 'Free gift at ' | append: gift_limit_formatted
    assign helper_text = 'Just ' | append: remaining_formatted | append: ' away from a free gift!'
    assign bar_state = 'active'
  else
    assign progress = cart_total | times: 50 | divided_by: shipping_limit
    assign remaining_cents = shipping_limit | minus: cart_total
    assign remaining_formatted = remaining_cents | money
    assign shipping_limit_formatted = shipping_limit | money
    assign status_text = 'Free shipping at ' | append: shipping_limit_formatted
    assign helper_text = 'Just ' | append: remaining_formatted | append: ' away from free shipping!'
    assign bar_state = 'active'
  endif
-%}

<div class="cart-progress-wrapper"
     data-hydration-key="cart-progress"
     data-shipping-threshold="{{ shipping_limit }}"
     data-gift-threshold="{{ gift_limit }}"
     data-gift-variant-id="{{ gift_variant_id }}"
     data-currency-symbol="{{ cart.currency.symbol }}"
     data-currency-code="{{ cart.currency.iso_code }}">

  {%- if cart.item_count > 0 -%}
    <div class="cart-progress{% if bar_state == 'complete' %} cart-progress--complete{% endif %}{% if cart_total < shipping_limit %} cart-progress--shipping{% else %} cart-progress--gift{% endif %}"
         role="progressbar"
         aria-valuenow="{{ progress }}"
         aria-valuemin="0"
         aria-valuemax="100"
         aria-label="{{ status_text }}">

      <p class="cart-progress__status{% if bar_state == 'complete' %} cart-progress__status--success{% endif %}">
        {{ status_text }}
      </p>

      <div class="cart-progress__track">
        <div class="cart-progress__fill{% if bar_state == 'complete' %} cart-progress__fill--complete{% endif %}"
             style="width: {{ progress | at_most: 100 }}%">
        </div>
      </div>

      {%- if helper_text != blank -%}
        <p class="cart-progress__helper">{{ helper_text }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

<style>
  /* ============================================
     PROGRESS BAR — Enhanced design
     ============================================ */
  .cart-progress-wrapper {
    padding: 0 var(--padding-lg, 16px);
  }

  .cart-progress {
    background: #F0F4F6;
    border-radius: 12px;
    padding: 16px 18px;
    margin: 8px 0 20px;
    transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
    box-shadow: 0 1px 4px rgba(0,47,108,0.05);
    border: 1px solid rgba(0,47,108,0.06);
  }

  /* Success state — gradient + glow */
  .cart-progress--complete {
    background: linear-gradient(135deg, #e8f5e0 0%, #d4edda 100%);
    border-color: rgba(74,149,0,0.15);
    box-shadow: 0 2px 8px rgba(74,149,0,0.08);
  }

  /* Status text with icon prefix */
  .cart-progress__status {
    font-size: 13px;
    font-weight: 600;
    color: #002F6C;
    margin: 0 0 10px;
    transition: color 0.4s ease;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .cart-progress__status::before {
    font-size: 14px;
    line-height: 1;
  }
  .cart-progress--shipping .cart-progress__status::before { content: '🚚'; }
  .cart-progress--gift .cart-progress__status::before { content: '🎁'; }
  .cart-progress--complete .cart-progress__status::before { content: '✨'; }

  .cart-progress__status--success { color: #4A9500; }

  /* Track + fill */
  .cart-progress__track {
    height: 7px;
    background: #d0d8de;
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }

  .cart-progress__fill {
    height: 100%;
    background: linear-gradient(90deg, #002F6C, #003d8f);
    border-radius: 4px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }
  .cart-progress__fill--complete {
    background: linear-gradient(90deg, #4A9500, #5cb800);
  }

  /* Helper text */
  .cart-progress__helper {
    font-size: 12px;
    color: #6b6d70;
    margin: 8px 0 0;
    line-height: 1.4;
  }

  /* ============================================
     CART LOADING OVERLAY — shown during gift ops
     ============================================ */
  .cart-gift-updating {
    position: relative;
    pointer-events: none;
  }
  .cart-gift-updating::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(1px);
    z-index: 10;
    border-radius: inherit;
    animation: cart-fade-in 0.15s ease;
  }
  @keyframes cart-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>

